def wavenum(period,depth,tolerance=1e-6,max_iterations=10):
    """
    Linear dispersion relation wavenumber solver.
    k = wavenum(period,depth)
    Solves for the wave-numbers 'k' for a given depth that satisfy the
    dispersion relation: omega^2 = g*k*tanh(k*depth) using the
    Newton-Raphson method.

        Modified from script created on Fri Apr 2 08:05:26 2021
        @author: sdbrenner
    """
    import numpy as np
    #convert period to angular frequency
    omega = 2*np.pi/period

    g = 9.81
    # initial guess based on Fenton and McKee, 1990:
    k0 = omega**2/g
    kn = k0* ( np.tanh((k0*depth)**(3/4)) )**(-2/3)
    converged = 0 #convergence flag
    # iterate with a Newton-Raphson method:
    for n in range(max_iterations):
        err = np.abs( omega**2 - g*kn*np.tanh(kn*depth) )
        if err<tolerance: #pre-debug: if all(err<tolerance):
            converged = 1
            break
        fkn = g*kn*np.tanh(kn*depth) - omega**2
        dfkn = g*np.tanh(kn*depth) + g*depth*kn/np.cosh(kn*depth)**2
        kn = kn - fkn/dfkn
    if converged == 0:
        print('did not converge')
    return kn

def part1():
    wave_t = np.array([4, 12, 8, 16])
    wave_d = np.array([5, 10, 100, 4000])
    wave_h = np.array([1,2,3,5])
    d_over_l = np.zeros(len(wave_t))
    kns = np.zeros(len(wave_t))
    L = np.zeros(len(wave_t))
    c = np.zeros(len(wave_t))
    u_max = np.zeros(len(wave_t))
    w_max = np.zeros(len(wave_t))

    for i in range(len(wave_t)):
        kns[i] = wavenum(wave_t[i], wave_d[i])
        L[i] = 2 * np.pi / kns[i]
        d_over_l[i] = wave_d[i] / L[i]
        print(f"For wave period {wave_t[i]}s and depth {wave_d[i]}, k = {kns[i]}, d/L = {d_over_l[i]}")
        if d_over_l[i] >= 0.5: #Deep water wave
            c[i] = 9.81*wave_t[i]/(2*np.pi)
            u_max[i] = 9.81*wave_h[i]/(2*c[i])
            w_max[i] = u_max[i]
        elif d_over_l[i] <= 0.05: #Shallow water wave
            c[i] = np.sqrt(9.81*wave_d[i])
        else: #Intermediate depth wave
            c[i] = L[i]/wave_t[i]
            u_max[i] = (np.pi*wave_h[i]/(wave_t[i])*(np.cosh(kns[i]*wave_d[i])/np.sinh(kns[i]*wave_d[i])))
            w_max[i] = (np.pi*wave_h[i]/(wave_t[i]))
        print(f"Wave period {wave_t[i]}s, depth {wave_d[i]}, c = {c[i]}, u_max = {u_max[i]}, w_max = {w_max[i]}")
    print("Done with part 1 and 2")

    #Part 3 - Pressures
    p_hydro = np.zeros(len(wave_t))
    p_tot = np.zeros(len(wave_t))
    K_p = np.zeros(len(wave_t))
    p_max_sol = np.zeros(len(wave_t))

    for i in range(len(wave_t)):
        p_hydro[i] = 1025 * 9.81 * wave_d[i]
        K_p[i] = np.cosh(kns[i]*(-wave_d[i]+wave_d[i]))/np.cosh(kns[i]*wave_d[i])
        p_tot[i] = 1025 * 9.81 * (wave_d[i] + K_p[i]*w_max[i]) #this is potentially wrong, not the solution provided not sure why not
        p_max_sol[i] = 1025 * 9.81 * (K_p[i] * wave_h[i]/2)
        print(f"For wave p eriod {wave_t[i]}s and depth {wave_d[i]}, p_hydro = {p_hydro[i]}, K_p = {K_p[i]}, p_tot = {p_tot[i]}, p_max_sol = {p_max_sol[i]}")
    
    #Part 4
    cg = np.zeros(len(wave_t))
    E = np.zeros(len(wave_t))
    flux = np.zeros(len(wave_t))

    for i in range(len(wave_t)):
        E[i] = (1/8)*1025*9.81*wave_h[i]**2

        if d_over_l[i] >= 0.5: #Deep water wave
            cg[i] = c[i]/2
        elif d_over_l[i] <= 0.05: #Shallow water wave
            cg[i] = c[i]
        else: #Intermediate depth wave
            cg[i] = c[i]/2 * (1 + (2*kns[i]*wave_d[i])/np.sinh(2*kns[i]*wave_d[i]))

        flux[i] = E[i]*cg[i]
        print(f"For wave period {wave_t[i]}s and depth {wave_d[i]}, cg = {cg[i]}, E = {E[i]}, flux = {flux[i]}")

    #Part 5
    stokes_drift = np.zeros(len(wave_t))
    y_axis = np.zeros(len(wave_t)) #to find place on nonlinear graph
    x_axis = np.zeros(len(wave_t))

    for i in range(len(wave_t)):
        stokes_drift[i] = (wave_h[i]**2 * kns[i]**2 * c[i])/(8) * (np.cosh(2*kns[i]*wave_d[i]))/np.sinh(kns[i]*wave_d[i])**2
        print(f"For wave period {wave_t[i]}s and depth {wave_d[i]}, Stokes Drift = {stokes_drift[i]}")
        y_axis[i] = wave_h[i]/(9.818*wave_t[i]**2)
        x_axis[i] = wave_d[i]/(9.81*wave_t[i]**2)
        print(f"For wave period {wave_t[i]}s and depth {wave_d[i]}, x_axis = {x_axis[i]}, y_axis = {y_axis[i]}")
        

