        uv = h*g*t/(2*L) * 1/np.sinh(k*d)
        if uv <= .25:
            d = d - 0.1
            #print(f'{d}, d')
        else:
            u = True
            print(f"Final depth is {d}m for wave period {t}s and height {h}m with u = {uv}")

    l_deep = g*t**2/(2*np.pi)
    k_deep = 2 * np.pi / l_deep
    usurf = h*np.pi/(t) * np.exp(k_deep*0)
    z_base = (np.log(usurf*0.05 * t / (np.pi *h))) / k_deep
    print(f"Deep water wave base is at {z_base}m for wave period {t}s and height {h}m with usurf = {usurf}")
    
    base = False
    while base == False:
        k = wavenum(t,d)
        L = 2 * np.pi / k
        ub = h*g*t/(2*L) * 1/np.sinh(k*d) * np.cosh(k*0)
        if ub <= .25:
            d = d + 0.1
            print(f'{d}, d')
        else:
            base = True
            print(f"Final depth is {d}m for wave period {t}s and height {h}m with ub = {ub}")

